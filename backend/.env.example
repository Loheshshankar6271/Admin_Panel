PORT=5000

# For production (Neon), set DATABASE_URL. Get this from your Neon dashboard.
# Example: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# For local development only (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=admin_dashboard
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET=your_super_secret_jwt_key_here

# Comma-separated list of allowed frontend origins
# Example: https://your-app.vercel.app,http://localhost:5173
CLIENT_URL=http://localhost:5173
